generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Authentification (Auth.js) ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?   // bcrypt, null si OAuth uniquement
  image         String?
  role          String    @default("USER") // "USER" | "ADMIN"
  banned        Boolean   @default(false)
  createdAt     DateTime  @default(now())

  accounts         Account[]
  sessions         Session[]
  resetTokens      PasswordResetToken[]
  watchlistEntries WatchlistEntry[]
  priceUpdates     Price[]
  priceChangeLogs  PriceChangeLog[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ── Cartes YGOProDeck ────────────────────────────────────────────────────────

model Card {
  id           Int       @id // ID YGOProDeck (pas autoincrement)
  name         String
  type         String
  frameType    String    @default("")
  description  String    @default("")
  atk          Int?
  def          Int?
  level        Int?
  race         String    @default("")
  attribute    String?
  imageUrl     String    // URL distante YGOProDeck
  hasLocalImage Boolean  @default(false)
  updatedAt    DateTime  @updatedAt

  cardSets         CardSet[]
  watchlistEntries WatchlistEntry[]
  prices           Price[]
  priceChangeLogs  PriceChangeLog[]

  @@index([name])
}

// Chaque ligne = combinaison unique (carte × édition × rareté)
model CardSet {
  id            Int    @id @default(autoincrement())
  cardId        Int
  setName       String
  setCode       String
  setRarity     String
  setRarityCode String @default("")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, setCode, setRarity])
  @@index([cardId])
  @@index([setName])
}

// ── Vendeurs CardMarket (pool global partagé) ────────────────────────────────

model Seller {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  shippingProfile String   @default("cardmarket-fr-standard")
  createdAt       DateTime @default(now())

  prices          Price[]
  priceChangeLogs PriceChangeLog[]
}

// ── Watchlist (par utilisateur) ──────────────────────────────────────────────

model WatchlistEntry {
  id        Int      @id @default(autoincrement())
  userId    String
  deck      String   @default("")
  cardId    Int
  quantity  Int      @default(1)
  setName   String?
  rarity    String?
  status    String   @default("")
  notes     String   @default("")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id])

  @@index([userId])
  @@index([cardId])
}

// ── Prix global (Card × Seller) ──────────────────────────────────────────────

model Price {
  id                Int       @id @default(autoincrement())
  cardId            Int
  sellerId          Int
  price             Float?
  previousPrice     Float?
  previousUpdatedAt DateTime?
  updatedAt         DateTime  @updatedAt
  updatedById       String?

  card        Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  seller      Seller  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  updatedBy   User?   @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([cardId, sellerId])
  @@index([cardId])
  @@index([sellerId])
}

// ── Journal des modifications de prix (notifications admin) ─────────────────

model PriceChangeLog {
  id          Int      @id @default(autoincrement())
  cardId      Int
  sellerId    Int
  oldPrice    Float?
  newPrice    Float?
  changedById String
  changedAt   DateTime @default(now())
  readByAdmin Boolean  @default(false)

  card      Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  seller    Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  changedBy User   @relation(fields: [changedById], references: [id], onDelete: Cascade)
}
