generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Authentification (Auth.js) ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?   // bcrypt, null si OAuth uniquement
  image         String?
  role          String    @default("USER") // "USER" | "ADMIN"
  banned        Boolean   @default(false)
  createdAt     DateTime  @default(now())

  accounts         Account[]
  sessions         Session[]
  resetTokens      PasswordResetToken[]
  watchlistEntries WatchlistEntry[]
  priceUpdates     Price[]
  priceChangeLogs  PriceChangeLog[]
  wavesCreated     Wave[]
  submissions      OrderSubmission[]
  notifications    Notification[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ── Cartes YGOProDeck ────────────────────────────────────────────────────────

model Card {
  id           Int       @id // ID YGOProDeck (pas autoincrement)
  name         String
  type         String
  frameType    String    @default("")
  description  String    @default("")
  atk          Int?
  def          Int?
  level        Int?
  race         String    @default("")
  attribute    String?
  imageUrl     String    // URL distante YGOProDeck
  hasLocalImage Boolean  @default(false)
  cardFormat   String    @default("BOTH") // "TCG" | "OCG" | "BOTH"
  updatedAt    DateTime  @updatedAt

  cardSets            CardSet[]
  watchlistEntries    WatchlistEntry[]
  prices              Price[]
  priceChangeLogs     PriceChangeLog[]
  submissionItems     OrderSubmissionItem[]

  @@index([name])
}

// Chaque ligne = combinaison unique (carte × édition × rareté)
model CardSet {
  id            Int    @id @default(autoincrement())
  cardId        Int
  setName       String
  setCode       String
  setRarity     String
  setRarityCode String @default("")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, setCode, setRarity])
  @@index([cardId])
  @@index([setName])
}

// ── Vendeurs (pool global partagé TCG+OCG) ───────────────────────────────────

model Seller {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  platform        String   @default("cardmarket") // "cardmarket" | "taobao" | "autre"
  shippingProfile String   @default("cardmarket-fr-standard")
  createdAt       DateTime @default(now())

  prices              Price[]
  priceChangeLogs     PriceChangeLog[]
  waveSellerEntries   WaveSeller[]
  submissionItems     OrderSubmissionItem[]
}

// ── Watchlist (par utilisateur) ──────────────────────────────────────────────

model WatchlistEntry {
  id        Int      @id @default(autoincrement())
  userId    String
  format    String   @default("TCG") // "TCG" | "OCG"
  deck      String   @default("")
  cardId    Int
  quantity  Int      @default(1)
  setName   String?
  rarity    String?
  status    String   @default("")
  notes     String   @default("")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  card            Card                  @relation(fields: [cardId], references: [id])
  submissionItems OrderSubmissionItem[]

  @@index([userId])
  @@index([cardId])
}

// ── Prix global (Card × Seller) ──────────────────────────────────────────────

model Price {
  id                Int       @id @default(autoincrement())
  cardId            Int
  sellerId          Int
  price             Float?
  previousPrice     Float?
  previousUpdatedAt DateTime?
  updatedAt         DateTime  @updatedAt
  updatedById       String?

  card        Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  seller      Seller  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  updatedBy   User?   @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([cardId, sellerId])
  @@index([cardId])
  @@index([sellerId])
}

// ── Journal des modifications de prix (notifications admin) ─────────────────

model PriceChangeLog {
  id          Int      @id @default(autoincrement())
  cardId      Int
  sellerId    Int
  oldPrice    Float?
  newPrice    Float?
  changedById String
  changedAt   DateTime @default(now())
  readByAdmin Boolean  @default(false)

  card      Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  seller    Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  changedBy User   @relation(fields: [changedById], references: [id], onDelete: Cascade)
}

// ── Vagues de commande groupée ───────────────────────────────────────────────

// status : "open" | "frozen" | "ordered" | "delivered"
model Wave {
  id          Int      @id @default(autoincrement())
  name        String
  status      String   @default("open")
  deadline    DateTime?
  createdAt   DateTime @default(now())
  createdById String

  createdBy   User              @relation(fields: [createdById], references: [id])
  sellers     WaveSeller[]
  submissions OrderSubmission[]
  notifications Notification[]

  @@index([status])
}

// Vendeurs désignés par l'admin pour une vague (table pivot)
model WaveSeller {
  waveId   Int
  sellerId Int

  wave   Wave   @relation(fields: [waveId], references: [id], onDelete: Cascade)
  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@id([waveId, sellerId])
}

// Soumission d'un user pour une vague
// status : "draft" | "submitted" | "confirmed" | "cancelled"
model OrderSubmission {
  id          Int       @id @default(autoincrement())
  waveId      Int
  userId      String
  status      String    @default("submitted")
  submittedAt DateTime  @default(now())
  confirmedAt DateTime?

  wave  Wave                  @relation(fields: [waveId], references: [id], onDelete: Cascade)
  user  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderSubmissionItem[]

  @@unique([waveId, userId])
  @@index([waveId])
  @@index([userId])
}

// Snapshot d'une ligne watchlist au moment de la soumission
model OrderSubmissionItem {
  id               Int     @id @default(autoincrement())
  submissionId     Int
  watchlistEntryId Int
  cardId           Int
  cardName         String
  setName          String  @default("")
  rarity           String  @default("")
  quantity         Int     @default(1)
  preferredSellerId Int?
  snapshotPrice    Float?  // prix capturé au moment de la soumission

  submission     OrderSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  watchlistEntry WatchlistEntry  @relation(fields: [watchlistEntryId], references: [id], onDelete: Cascade)
  card           Card            @relation(fields: [cardId], references: [id])
  preferredSeller Seller?        @relation(fields: [preferredSellerId], references: [id], onDelete: SetNull)

  @@index([submissionId])
  @@index([watchlistEntryId])
}

// ── Notifications in-app ─────────────────────────────────────────────────────

// type : "wave_open" | "wave_frozen" | "wave_ordered" | "wave_delivered"
//        | "submission_received"
model Notification {
  id        Int      @id @default(autoincrement())
  userId    String
  type      String
  title     String
  body      String   @default("")
  payload   String   @default("{}") // JSON sérialisé
  waveId    Int?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  wave Wave? @relation(fields: [waveId], references: [id], onDelete: SetNull)

  @@index([userId, readAt])
  @@index([waveId])
}
